# Use csv for local development and databricks for Unity Catalog Delta storage.
STORAGE_MODE=csv

# Local CSV storage.
LOCAL_CSV_PATH=data/request_logs.csv

# Unity Catalog table details used when STORAGE_MODE=databricks.
UC_CATALOG=main
UC_SCHEMA=request_management
UC_DATABASE=request_management
UC_TABLE=request_logs

# Databricks Connect and Databricks SDK settings.
# DATABRICKS_HOST should include https://, for example https://adb-xxx.azuredatabricks.net.
DATABRICKS_HOST=
DATABRICKS_CLUSTER_ID=
DATABRICKS_TOKEN=

# Defaults and editable form choices.
DEFAULT_ASSIGNEE=Shared Delivery Queue
BUSINESS_UNITS=Gas,ES
DEVELOPMENT_TYPES=Fault,Dev
PLATFORMS=Capacity App,PowerBI
PRIORITIES=High,Medium,Low
REQUEST_STATUSES=Pending,In Progress,Hold,Completed,Cancelled

# Assignment rules are keyed as "Business Unit|Platform".
ASSIGNMENT_RULES={"Gas|Capacity App":"Gas Capacity Team","Gas|PowerBI":"Gas BI Team","ES|Capacity App":"ES Capacity Team","ES|PowerBI":"ES BI Team"}
